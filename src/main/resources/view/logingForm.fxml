<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="415.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LogingFormController">
   <children>
      <PasswordField fx:id="txtPassword" layoutX="100.0" layoutY="182.0" prefHeight="36.0" prefWidth="216.0" promptText="Password" style="-fx-background-radius: 10;" />
      <TextField fx:id="txtEmail" layoutX="99.0" layoutY="115.0" prefHeight="36.0" prefWidth="216.0" promptText="Email" style="-fx-background-radius: 10;" />
      <Button layoutX="100.0" layoutY="252.0" mnemonicParsing="false" onAction="#clickedSingIn" prefHeight="36.0" prefWidth="216.0" style="-fx-background-radius: 10; -fx-background-color: #005eff;" text="Sing In" textFill="WHITE" />
      <Label layoutX="149.0" layoutY="27.0" text="Sing In">
         <font>
            <Font size="38.0" />
         </font>
      </Label>
      <Label layoutX="110.0" layoutY="314.0" text="Don't have an account ?" />
      <Label layoutX="243.0" layoutY="314.0" onMouseClicked="#clickedCreateAnAccount" text="Create one" textFill="#005eff" />
   </children>
</AnchorPane>
